      "link": null,
      "locked": false,
      "text": "calculate ghost moving direction on the following events\n1- pac man changed his movement direction\n2- ghost can't move any more\n3- automatic movement (pac man didn't change movement \n                             direction and the ghost is still able to move)\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "calculate ghost moving direction on the following events\n1- pac man changed his movement direction\n2- ghost can't move any more\n3- automatic movement (pac man didn't change movement \n                             direction and the ghost is still able to move)\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
